{
  "expo": {
    "name": "XpressCart",
    "version": "1.0.22",
    "scheme": "xpresscart",
    "description": "XpressCart - Fast & fresh food delivery at your fingertips. Order from your favorite restaurants with real-time tracking and seamless payments.",
    "slug": "xpresscart",
    "owner": "partharsid",
    "currentFullName": "@partharsid/xpresscart",
    "originalFullName": "@partharsid/xpresscart",
    "privacy": "public",
    "androidStatusBar": {
      "backgroundColor": "#000"
    },
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#E63946"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xpresscart.customer",
      "googleServicesFile": "./GoogleService-Info.plist",
      "config": {
        "googleMapsApiKey": ""
      },
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses the location to determine the delivery address for your orders.",
        "NSUserTrackingUsageDescription": "Allow this app to collect app-related data that can be used for tracking you or your device."
      }
    },
    "notification": {
      "iosDisplayInForeground": true,
      "color": "#E63946",
      "icon": "./assets/not-icon.png",
      "androidMode": "default",
      "androidCollapsedTitle": "XpressCart"
    },
    "android": {
      "versionCode": 26,
      "package": "com.xpresscart.customer",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCzNP5qQql2a5y8lOoO-1yj1lj_tzjVImA"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E63946"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "Allow this app to collect app-related data that can be used for tracking you or your device."
        }
      ]
    ],
    "facebookScheme": "fb3017447961609878",
    "facebookAppId": "3017447961609878",
    "facebookDisplayName": "Food delivery",
    "extra": {
      "eas": {
        "projectId": "e8d09902-318c-4758-b320-d3d2718161e9"
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    }
  }
}
